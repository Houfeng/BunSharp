{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "coreclr",
      "request": "launch",
      "name": "Debug BunSharp.Demo",
      "preLaunchTask": "build BunSharp.Demo",
      "program": "${workspaceFolder}/BunSharp.Demo/bin/Debug/net10.0/BunSharp.Demo.dll",
      "cwd": "${workspaceFolder}",
      "args": ["BunSharp.Demo/assets/debug.ts"],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "startDebugging",
        "pattern": "Bun Inspector",
        "name": "Attach Bun"
      }
    },
    {
      "type": "bun",
      "request": "attach",
      "name": "Attach Bun",
      "url": "ws://127.0.0.1:6499/debug",
      "stopOnEntry": false
    }
  ]
}